# TornOps Configuration
# Copy this file to your data folder as .env

APP_NAME="TornOps"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Choose one: sqlite or mysql
# SQLite (simpler - file-based)
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite

# MariaDB (if using external database)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=tornops
# DB_USERNAME=tornops
# DB_PASSWORD=tornops123

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_STORE=file

# Required: Get from https://www.torn.com/preferences.php#tab=api
TORN_API_KEY=your_api_key_here